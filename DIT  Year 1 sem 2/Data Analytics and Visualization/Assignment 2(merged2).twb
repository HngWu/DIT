    <worksheet name='Repayment/recovery status based on income'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#ffaa00'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Output Extract' name='federated.1p71il601k75581by5r8v0krntrp' />
          </datasources>
          <datasource-dependencies datasource='federated.1p71il601k75581by5r8v0krntrp'>
            <column caption='Annual Income' datatype='real' name='[AnnualIncome]' role='measure' type='quantitative' />
            <column caption='Income' datatype='string' name='[Calculation1 (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[Calculation_883268527988330497]' new-bin='true'>
                <bin default-name='false' value='&quot;$1-$49,999&quot;'>
                  <value>0</value>
                </bin>
                <bin default-name='false' value='&quot;$100,000-$149,999&quot;'>
                  <value>100000</value>
                </bin>
                <bin default-name='false' value='&quot;$150,000-$199,999&quot;'>
                  <value>150000</value>
                </bin>
                <bin default-name='false' value='&quot;$200,000-$249,999&quot;'>
                  <value>200000</value>
                </bin>
                <bin default-name='false' value='&quot;$250,000-$299,999&quot;'>
                  <value>250000</value>
                </bin>
                <bin default-name='false' value='&quot;$300,000-349,999&quot;'>
                  <value>300000</value>
                </bin>
                <bin default-name='false' value='&quot;$50,000-$99,999&quot;'>
                  <value>50000</value>
                </bin>
                <bin default-name='false' value='&quot;&gt;=$350,000&quot;'>
                  <value>350000</value>
                </bin>
              </calculation>
            </column>
            <column caption='Calculation1' datatype='integer' name='[Calculation_883268527988330497]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT([AnnualIncome] / 50000) * 50000' />
            </column>
            <column caption='Loan Status' datatype='string' name='[LoanStatus]' role='dimension' type='nominal' />
            <column-instance column='[LoanStatus]' derivation='Count' name='[cnt:LoanStatus:qk]' pivot='key' type='quantitative' />
            <column-instance column='[LoanStatus]' derivation='None' name='[none:LoanStatus:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <natural-sort column='[federated.1p71il601k75581by5r8v0krntrp].[Calculation1 (group)]' direction='ASC' />
          <filter class='categorical' column='[federated.1p71il601k75581by5r8v0krntrp].[none:LoanStatus:nk]'>
            <groupfilter function='except' user:ui-domain='relevant' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[none:LoanStatus:nk]' />
              <groupfilter function='member' level='[none:LoanStatus:nk]' member='&quot;Active&quot;' />
            </groupfilter>
          </filter>
          <_.fcp.SingleValuePerNestSorting.true...single-value-per-nest-shelf-sorts>
            <single-value-per-nest-shelf-sort dimension-to-sort='[federated.1p71il601k75581by5r8v0krntrp].[none:LoanStatus:nk]' direction='ASC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1p71il601k75581by5r8v0krntrp].[none:LoanStatus:nk]' shelf='rows' />
          </_.fcp.SingleValuePerNestSorting.true...single-value-per-nest-shelf-sorts>
          <slices>
            <column>[federated.1p71il601k75581by5r8v0krntrp].[none:LoanStatus:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
